# ═══════════════════════════════════════════════════════════
# MicroVest v10 — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git!
# ═══════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your_anon_key
SUPABASE_SERVICE_KEY=eyJhbGci...your_service_role_key

# ── App ───────────────────────────────────────────────────────
APP_VERSION=10.0
APP_ENV=production
APP_URL=https://microvest.netlify.app

# ── Web Push VAPID (generate: npm run vapid:gen) ──────────────
VAPID_PUBLIC_KEY=BEl62iUYgUivxIk...
VAPID_PRIVATE_KEY=abc123def456...
VAPID_EMAIL=mailto:admin@microvest.app

# ── Admin ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ADMIN_SECRET_KEY=your-super-secret-admin-key-min-32-chars
