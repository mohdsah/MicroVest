# MicroVest v8 — Netlify _redirects
# Force HTTPS
http://microvest.app/*      https://microvest.app/:splat     301!
http://www.microvest.app/*  https://microvest.app/:splat     301!
https://www.microvest.app/* https://microvest.app/:splat     301!

# Admin shortcut
/admin                      /admin/dashboard.html             302

# Referral shortcut: /ref/REFCODE → login.html?ref=REFCODE
/ref/:code                  /login.html?ref=:code             302

# Invite shortcut
/invite/:code               /login.html?ref=:code             302

# PWA start_url redirect
/app                        /dashboard.html                   302

# SPA 404 fallback
/*                          /404.html                         404
